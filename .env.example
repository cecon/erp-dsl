# Forge Agent — Variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha os valores

# GitHub Personal Access Token (scope: repo)
# Crie em: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Repositório GitHub no formato org/repo
GITHUB_REPO=cecon/erp-dsl

# Branch base para PRs (default: main)
GITHUB_BASE_BRANCH=main

# Nota: o Gemini é autenticado via OAuth (gemini auth login)
# Não é necessário API key — faça login após subir o container:
#   docker compose exec forge-worker gemini auth login
